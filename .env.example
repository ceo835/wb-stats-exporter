# WB API
WB_TOKEN=ey...

# Logging
LOG_LEVEL=INFO
FILTER_ZERO_SPEND=true

# Google Sheets (optional)
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_SPREADSHEET_ID=
# Prefix for sheets created from the ads analytics tab
ADS_GOOGLE_EXPORT_PREFIX=AdsStats
# For Streamlit Cloud you can provide raw JSON instead of file path:
# GOOGLE_CREDENTIALS_JSON={"type":"service_account", ...}

# Telegram notifications (optional, for auto_export.py)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# MPSTATS positions collector
MPSTATS_API_TOKEN=
# Optional: override if your endpoint differs (must contain `{sku}`)
MPSTATS_POSITION_URL=https://mpstats.io/api/wb/get/item/{sku}/by_keywords

# WB Analytics fallback for own-brand items
WB_ANALYTICS_TOKEN=
# Optional: override own-brand endpoint
WB_ANALYTICS_POSITION_URL=https://seller-analytics-api.wildberries.ru/api/v2/search-report/product/orders
# Optional: if 1, fallback to MPSTATS even when WB returns `not_found`
WB_FALLBACK_ON_NOT_FOUND=0

# WB Content API for product names
# Optional; priority: WB_CONTENT_TOKEN -> WB_API_TOKEN -> WB_TOKEN
WB_CONTENT_TOKEN=
# Optional alias for WB Content token
WB_API_TOKEN=
WB_CONTENT_URL=https://content-api.wildberries.ru/content/v2/get/cards/list

# Optional fallback if you do not use `is_own_brand` column in settings:
# comma-separated list of own-brand nm_id values
MY_NM_IDS=

# Positions storage sheets
POSITIONS_SETTINGS_SHEET=Настройки
POSITIONS_RAW_SHEET=Positions_Raw
POSITIONS_STATE_SHEET=Positions_State

# Optional local CSV fallback for settings loader
POSITIONS_SETTINGS_CSV=
# Local cache for nm_id -> product_name
POSITIONS_NM_CACHE_FILE=nm_id_cache.json
# Optional alias for own-brand ids (works like MY_NM_IDS)
POSITIONS_MY_NM_IDS=

# Collector timing
POSITIONS_TIMEZONE=Europe/Moscow
POSITIONS_REQUEST_PAUSE_SECONDS=0.7

# Matrix sheets in Google Sheets (query-based wide tables)
POSITIONS_MATRIX_ENABLED=0
POSITIONS_MATRIX_FROM_MONTH_START=1
POSITIONS_MATRIX_INDEX_SHEET=Positions_Matrix_Index
POSITIONS_MATRIX_SHEET_PREFIX=Matrix

# Category sheets in Google Sheets (grouped wide tables)
POSITIONS_CATEGORY_MATRIX_ENABLED=1
POSITIONS_CATEGORY_INDEX_SHEET=Positions_Category_Index
POSITIONS_CATEGORY_SHEET_PREFIX=Category

