# WB API
WB_TOKEN=ey...

# Logging
LOG_LEVEL=INFO
FILTER_ZERO_SPEND=true

# Google Sheets (optional)
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_SPREADSHEET_ID=
